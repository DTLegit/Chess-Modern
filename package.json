{
  "name": "chess",
  "version": "0.1.0",
  "private": true,
  "description": "A polished, native cross-platform chess game built with Tauri 2.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
