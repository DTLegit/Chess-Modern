  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.55.5",
    "svelte-check": "^4.1.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.10"
  }
