{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimum permissions for the Chess app: typed Tauri commands, event listeners, and the bundled Stockfish sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/stockfish",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
